{
  "compilerOptions": {
    "target": "ES2022",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "types": ["node", "@playwright/test"],

    "resolveJsonModule": true,
    "esModuleInterop": true,

    "strict": true,
    "skipLibCheck": true
  },

  "include": [
    "tests/**/*.ts",
    "pages/**/*.ts",
    "flows/**/*.ts",
    "utils/**/*.ts",
    "playwright.config.ts"
  ]
}